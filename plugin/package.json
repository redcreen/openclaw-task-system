{
  "name": "@redcreen/openclaw-task-system",
  "version": "0.2.0",
  "description": "Plugin-first task lifecycle management for OpenClaw long-running work",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "task-management",
    "watchdog",
    "agent-runtime"
  ],
  "files": [
    "index.ts",
    "src/**/*.ts",
    "scripts/runtime/**/*",
    "config/**/*.json",
    "data/readme.md",
    "openclaw.plugin.json",
    "readme.md"
  ],
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
