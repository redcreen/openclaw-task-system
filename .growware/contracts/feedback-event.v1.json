{
  "schema": "growware.feedback-event.v1",
  "required": [
    "project_id",
    "channel",
    "account_id",
    "message_id",
    "feedback_type",
    "human_text",
    "timestamp"
  ],
  "properties": {
    "project_id": "string",
    "channel": "string",
    "account_id": "string",
    "message_id": "string",
    "feedback_type": "idea | bug | regression | approval | rejection | deploy-request",
    "human_text": "string",
    "related_session": "string|null",
    "related_task_id": "string|null",
    "requires_reply": "boolean",
    "timestamp": "ISO-8601 string"
  }
}
